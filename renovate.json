{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeMinor",
    ":automergePr",
    ":automergeRequireAllStatusChecks"
  ],
  "packageRules": [
    {
      "description": "Require manual review for major version upgrades.",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ]
}
